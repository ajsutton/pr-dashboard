# Copy to .env (gitignored) and edit. Read by docker compose at launch.
# Tokens (GH_TOKEN, CITOKEN) go in .secrets/ as files instead — see README.

# UID/GID the container should run as. Set to your host user so the container
# isn't running as root. Get the values with `id -u` / `id -g`, or run:
#   echo "UID=$(id -u)" >> .env
#   echo "GID=$(id -g)" >> .env
# UID=1000
# GID=1000

# Optional: comma-separated owner/repo list. When set, the dashboard scopes
# everything (your PRs, assigned issues, review requests) to just these repos —
# anything outside them is ignored. Leave empty to show your PRs everywhere.
# DASHBOARD_REPOS=org/repo-a,org/repo-b

# Optional: set to 1 to keep showing your PRs/issues/reviews across ALL repos
# even when DASHBOARD_REPOS is set (the listed repos are then just pinned, not
# a filter — the previous default behaviour).
# DASHBOARD_ALL_REPOS=1

# Optional: host IP the published port binds to. Defaults to 127.0.0.1
# (loopback only). Set to 0.0.0.0 to expose the dashboard to your LAN.
# BIND_HOST=0.0.0.0

# Optional: set to 1 to trace every GitHub + CircleCI request/response (incl.
# partial GraphQL `errors`) to the logs. Use to debug an empty/blank board.
# Same as passing --debug to the server. Very verbose; leave off normally.
# DASHBOARD_DEBUG=1
