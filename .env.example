# Copy to .env (gitignored) and edit. Read by docker compose at launch.
# Tokens (GH_TOKEN, CITOKEN) go in .secrets/ as files instead — see README.

# UID/GID the container should run as. Set to your host user so the container
# isn't running as root. Get the values with `id -u` / `id -g`, or run:
#   echo "UID=$(id -u)" >> .env
#   echo "GID=$(id -g)" >> .env
# UID=1000
# GID=1000

# Optional: comma-separated owner/repo list to always show on the dashboard,
# even when you have no open PRs against them. Repos with open PRs are still
# discovered automatically and appear after the pinned ones.
# DASHBOARD_REPOS=org/repo-a,org/repo-b

# Optional: host IP the published port binds to. Defaults to 127.0.0.1
# (loopback only). Set to 0.0.0.0 to expose the dashboard to your LAN.
# BIND_HOST=0.0.0.0
